# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง  (cp .env.example .env)

# Supabase — เอาจาก Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxx.supabase.co
# ใช้ service_role key (ฝั่ง server เท่านั้น — ห้ามใส่ในเว็บ!)
SUPABASE_SERVICE_KEY=eyJhbGci...service_role...

# ความถี่ในการเช็คคิว (วินาที)
POLL_INTERVAL=60

# โฟลเดอร์ทำงานชั่วคราวสำหรับดาวน์โหลดไฟล์ก่อนอัป
WORK_DIR=./tmp

# ---- Platform API credentials (กรอกเมื่อพร้อมต่อ API จริง) ----
# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Facebook Graph API
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Shopee / Lazada Open Platform
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
LAZADA_APP_KEY=
LAZADA_APP_SECRET=

# ---- Google Drive (ดึงไฟล์) ----
GDRIVE_SERVICE_ACCOUNT_JSON=./gdrive-sa.json
